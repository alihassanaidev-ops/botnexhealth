# =============================================================================
# BotNexHealth Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
APP_ENV=production
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# NexHealth API Configuration (REQUIRED)
# -----------------------------------------------------------------------------
NEXHEALTH_API_KEY=your-nexhealth-api-key-here
NEXHEALTH_SUBDOMAIN=your-practice-subdomain
NEXHEALTH_LOCATION_ID=your-location-id

# NexHealth API Settings (defaults shown)
# NEXHEALTH_BASE_URL=https://nexhealth.info
# NEXHEALTH_API_VERSION=v2
# NEXHEALTH_ACCEPT=application/vnd.Nexhealth+json;version=2

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# Retell AI webhook secret (required for voice agent)
RETELL_API_SECRET=your-retell-api-secret

# -----------------------------------------------------------------------------
# Sikka API Configuration (OPTIONAL)
# -----------------------------------------------------------------------------
# Sikka API credentials (for Sikka integration)
SIKKA_APP_ID=your-sikka-app-id
SIKKA_APP_SECRET=your-sikka-app-secret

# -----------------------------------------------------------------------------
# Optional: Redis Configuration (for multi-worker deployments)
# -----------------------------------------------------------------------------
# REDIS_URL=redis://redis:6379/0

# -----------------------------------------------------------------------------
# Optional: Development Tools
# -----------------------------------------------------------------------------
# NGROK_AUTH_TOKEN=your-ngrok-token

# -----------------------------------------------------------------------------
# JWT Configuration (REQUIRED - no default)
# -----------------------------------------------------------------------------
JWT_SECRET=generate-a-strong-random-key-here
